---
const session = Astro.cookies.get('user_session');
const isLoggedIn = !!session;

import '../styles/global.css';
---
<html lang="id" data-theme="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Alif.Tech | Agensi Web Profesional</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
		<style is:global>
			@keyframes shimmer { 100% { transform: translateX(100%); } }
			details > summary { list-style: none; }
			details > summary::-webkit-details-marker { display: none; }
			.hide-scrollbar::-webkit-scrollbar { display: none; }
			.hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
			.kursor-tarik { cursor: grab; }
			.kursor-tarik:active { cursor: grabbing; }
			@keyframes blink { 0%, 100% { border-color: transparent; } 50% { border-color: #EA580C; } }
			
			/* ========================================================
			   🌟 PREMIUM SCROLLBAR
			   ======================================================== */
			::-webkit-scrollbar { width: 10px; }
			::-webkit-scrollbar-track { background: #0F172A; }
			::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; border: 2px solid #0F172A; }
			::-webkit-scrollbar-thumb:hover { background: #3B82F6; }
			
			[data-theme="light"] ::-webkit-scrollbar-track { background: #F5EEDB !important; }
			[data-theme="light"] ::-webkit-scrollbar-thumb { background: #C8B8A3 !important; border: 2px solid #F5EEDB !important; }
			[data-theme="light"] ::-webkit-scrollbar-thumb:hover { background: #EA580C !important; }

			/* ========================================================
			   🏗️ GLOBAL STRUCTURE & SHAPES (BERLAKU UNTUK KEDUA MODE)
			   ======================================================== */
			.bg-slate-800, .mockup-container, #terminal-card, #stats-container, section div.bg-gradient-to-r {
				border-radius: 1.5rem !important;
				transition: all 0.4s ease-in-out !important;
				background-image: none !important; 
			}
			.bg-slate-800:hover, .mockup-container:hover {
				transform: translateY(-5px) !important;
			}
			
			div#stats-grid > * { border: none !important; }
			#fitur-grid-section { border: none !important; box-shadow: none !important; }
			#fitur-grid div.bg-slate-800 > div { border: none !important; }

			#arsitektur-section .w-12.h-12, #arsitektur-section .w-14.h-14 {
				border-radius: 50% !important;
			}

			.portfolio-btn { border: none !important; transition: background-color 0.3s ease !important; }
			.mockup-category { transition: all 0.3s ease; border: 1px solid transparent !important; }
			
			#hero-glow { display: block !important; filter: blur(80px) !important; transition: all 0.7s ease !important; }
			footer { border-top: none !important; }

			/* ========================================================
			   🌙 DARK MODE COLORS
			   ======================================================== */
			body { background-color: #0F172A; } 
			
			.bg-slate-800, #terminal-card, #stats-container, section div.bg-gradient-to-r {
				background-color: #1E293B !important; 
				border: 1px solid #334155 !important;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2) !important;
			}
			.bg-slate-800:hover, .mockup-container:hover {
				box-shadow: 0 12px 25px rgba(59, 130, 246, 0.15) !important;
				border-color: #3B82F6 !important;
			}
			
			.border-slate-800, .border-slate-700, .border-2, .border-t-2, .border-b-2 {
				border-color: #334155 !important; border-width: 1px !important; }
			.divide-slate-700 > :not([hidden]) ~ :not([hidden]) { border-color: transparent !important; }

			#typewriter { color: #3B82F6 !important; -webkit-text-fill-color: #3B82F6 !important; }

			.mockup-header { background-color: #0F172A !important; border-bottom: 1px solid #334155 !important; }
			.mockup-url { background-color: #1E293B !important; color: #94A3B8 !important; border: 1px solid #334155 !important; }
			.mockup-body { background-color: #1E293B !important; }
			.mockup-banner { background-color: #0F172A !important; border-color: #334155 !important; color: #64748B !important; }
			.mockup-category { background-color: #0F172A !important; }
			.mockup-category:hover { border-color: #3B82F6 !important; box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2) !important; }
			.mockup-icon-bg { background-color: #1E293B !important; border: 1px solid #334155 !important; }
			.mockup-text { color: #94A3B8 !important; }

			#hero-glow { background-color: rgba(59, 130, 246, 0.15) !important; }
			.group:hover #hero-glow { background-color: rgba(59, 130, 246, 0.25) !important; }

			#pita-umkm-section { background-color: #020617 !important; border-radius: 0 !important; } 

			.portfolio-img-bg { background-color: #0F172A !important; }
			.portfolio-btn { background-color: #3B82F6 !important; color: #FFFFFF !important; }
			.portfolio-btn:hover { background-color: #2563EB !important; }
			#btn-portofolio { background-color: #1E293B !important; color: #E2E8F0 !important; border: 1px solid #334155 !important; }
			#btn-portofolio:hover { border-color: #3B82F6 !important; color: #3B82F6 !important; }

			#arsitektur-section .w-12.h-12, #arsitektur-section .w-14.h-14 {
				background-color: #1E293B !important; border: 1px solid #334155 !important; color: #3B82F6 !important;
			}

			footer { background-color: #020617 !important; border-top: 1px solid #1E293B !important; }
			footer .bg-blue-600 { background-color: #3B82F6 !important; color: #FFFFFF !important; }
			
			section, .border-t, .border-b, .border-y { border-color: transparent !important; }

			/* ========================================================
			   ☀️ LIGHT MODE COLORS (TERRACOTTA & BEIGE OVERRIDES)
			   ======================================================== */
			[data-theme="light"] body { background-color: #F5EEDB !important; color: #2E1F1A !important; }
			
			/* Penghapus Latar Belakang Default (Transparan) */
			[data-theme="light"] .bg-slate-900, [data-theme="light"] .bg-slate-950, 
			[data-theme="light"] .bg-slate-900\/50, [data-theme="light"] .bg-slate-800\/30 { 
				background-color: transparent !important;
			}
			
			[data-theme="light"] header .bg-slate-950 { background-color: #F5EEDB !important; border: none !important; }
			[data-theme="light"] nav.bg-slate-900\/85 { background-color: rgba(245, 238, 219, 0.85) !important; border-bottom: 1px solid #E3D5C1 !important; }
			[data-theme="light"] #mobile-menu { background-color: rgba(245, 238, 219, 0.98) !important; }

			[data-theme="light"] .bg-slate-800, [data-theme="light"] #terminal-card, 
			[data-theme="light"] #stats-container, [data-theme="light"] section div.bg-gradient-to-r {
				background-color: #E3D5C1 !important;
				border: none !important;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03) !important;
			}
			[data-theme="light"] .bg-slate-800:hover, [data-theme="light"] .mockup-container:hover { 
				box-shadow: 0 12px 25px rgba(234, 88, 12, 0.1) !important;
				border-color: transparent !important;
			}

			/* FIXED BUG KOTAK: Menghapus border-width: 1px !important yang merusak footer */
			[data-theme="light"] .border-slate-800, [data-theme="light"] .border-slate-700, 
			[data-theme="light"] .border-2, [data-theme="light"] .border-t-2, [data-theme="light"] .border-b-2 { 
				border-color: #C8B8A3 !important;
			}

			[data-theme="light"] .text-white { color: #2E1F1A !important; }
			[data-theme="light"] .text-slate-300 { color: #2E1F1A !important; font-weight: 600 !important; }
			[data-theme="light"] .text-slate-400 { color: #7B6153 !important; font-weight: 500 !important; }
			[data-theme="light"] .text-slate-500 { color: #8A8173 !important; font-weight: 500 !important; }
			[data-theme="light"] .text-blue-500, [data-theme="light"] .text-blue-400, 
			[data-theme="light"] .text-emerald-500, [data-theme="light"] .text-purple-500 { color: #EA580C !important; } 
			[data-theme="light"] #typewriter { color: #EA580C !important; -webkit-text-fill-color: #EA580C !important; }
			[data-theme="light"] .border-cyan-400 { border-color: #EA580C !important; }

			[data-theme="light"] .bg-blue-600, [data-theme="light"] a.bg-white.text-blue-600 { 
				background-color: #2E1F1A !important; color: #F5EEDB !important; border: none !important; 
			}
			[data-theme="light"] .bg-blue-600:hover, [data-theme="light"] a.bg-white.text-blue-600:hover { background-color: #4A332A !important; }
			[data-theme="light"] #btn-portofolio { background-color: #E3D5C1 !important; color: #2E1F1A !important; border: 1px solid #C8B8A3 !important; }
			[data-theme="light"] #btn-portofolio:hover { background-color: #C8B8A3 !important; border-color: #C8B8A3 !important; color: #2E1F1A !important; }

			[data-theme="light"] #theme-toggle-desktop, [data-theme="light"] #theme-toggle-mobile { 
				background-color: transparent !important; border: 1px solid #C8B8A3 !important; color: #2E1F1A !important;
			}
			[data-theme="light"] #theme-toggle-desktop:hover, [data-theme="light"] #theme-toggle-mobile:hover { background-color: #E5E7EB !important; color: #EA580C !important; }
			[data-theme="light"] a.fixed.bottom-6.right-6 svg.w-8.h-8 { color: #FFFFFF !important; }

			[data-theme="light"] .mockup-container { background-color: #E3D5C1 !important; border: 1px solid #C8B8A3 !important; }
			[data-theme="light"] .mockup-header { background-color: #E3D5C1 !important; border-bottom: 1px solid #C8B8A3 !important; }
			[data-theme="light"] .mockup-url { background-color: #F5EEDB !important; color: #7B6153 !important; border: 1px solid #C8B8A3 !important; }
			[data-theme="light"] .mockup-body { background-color: #E3D5C1 !important; }
			[data-theme="light"] .mockup-banner { background-color: #F5EEDB !important; border-color: #C8B8A3 !important; color: #7B6153 !important; }
			[data-theme="light"] .mockup-category { background-color: #F5EEDB !important; }
			[data-theme="light"] .mockup-category:hover { border-color: #EA580C !important; box-shadow: 0 4px 12px rgba(234, 88, 12, 0.15) !important; }
			[data-theme="light"] .mockup-icon-bg { background-color: #E3D5C1 !important; border: 1px solid #C8B8A3 !important; }
			[data-theme="light"] .mockup-text { color: #7B6153 !important; }

			[data-theme="light"] #hero-glow { background-color: rgba(234, 88, 12, 0.25) !important; }
			[data-theme="light"] .group:hover #hero-glow { background-color: rgba(234, 88, 12, 0.35) !important; }

			[data-theme="light"] #pita-umkm-section { background-color: #2E1F1A !important; border: none !important; }
			[data-theme="light"] #pita-umkm-section p, [data-theme="light"] #pita-umkm-section span { color: #EA580C !important; }
			[data-theme="light"] #pita-umkm-section .font-extrabold { color: #E3D5C1 !important; }

			[data-theme="light"] .portfolio-img-bg { background-color: #F5EEDB !important; }
			[data-theme="light"] .portfolio-btn { background-color: #EA580C !important; color: #F5EEDB !important; border: none !important; }
			[data-theme="light"] .portfolio-btn:hover { background-color: #C0470A !important; }

			[data-theme="light"] #arsitektur-section .w-12.h-12, [data-theme="light"] #arsitektur-section .w-14.h-14 {
				background-color: #E3D5C1 !important; border: 1px solid #C8B8A3 !important; color: #EA580C !important;
			}

			/* FOOTER WARNA HITAM PEKAT & TEKS KREM */
			[data-theme="light"] footer.bg-slate-950 { background-color: #2E1F1A !important; border-top: none !important; }
			[data-theme="light"] footer h4, 
			[data-theme="light"] footer p, 
			[data-theme="light"] footer a, 
			[data-theme="light"] footer span, 
			[data-theme="light"] footer ul,
			[data-theme="light"] footer .text-white,
			[data-theme="light"] footer .text-slate-400,
			[data-theme="light"] footer .text-slate-500 { 
				color: #F5EEDB !important;
			}
			[data-theme="light"] footer .bg-blue-600 { background-color: #EA580C !important; color: #F5EEDB !important; }
			[data-theme="light"] footer .bg-blue-600\/10 { background-color: transparent !important; border: 1px solid #F5EEDB !important; color: #F5EEDB !important; }

			/* CLEANUP TAMBAHAN */
			[data-theme="light"] section, [data-theme="light"] .border-t, [data-theme="light"] .border-b, [data-theme="light"] .border-y { border-color: transparent !important; }
			[data-theme="light"] .bg-blue-600\/20 { display: none !important; } 
		</style>
	</head>
	<body class="bg-slate-900 text-slate-300 font-sans antialiased selection:bg-blue-500 selection:text-white flex flex-col min-h-screen transition-colors duration-500" style="font-family: 'Inter', sans-serif;">
		
		<header class="fixed w-full top-0 z-50 transition-all shadow-sm backdrop-blur-lg">
			<div class="bg-slate-950 border-b border-slate-800 hidden lg:block transition-colors duration-500">
				<div class="container mx-auto px-6 py-2 flex justify-between items-center text-xs text-slate-400 font-medium">
					<div class="flex items-center gap-6">
						<span>📞 +62 812-3456-7890</span>
						<span>⏰ Setiap Hari 09.00 - 21.00</span>
					</div>
					<div class="flex items-center gap-1 cursor-pointer hover:text-blue-500 transition">🌐 ID</div>
				</div>
			</div>
			
			<nav class="bg-slate-900/85 relative z-50 transition-colors duration-500 border-b border-slate-800/50">
				<div class="container mx-auto px-6 py-4 flex justify-between items-center">
					<a href="/" class="text-3xl font-extrabold text-white tracking-tight flex items-center gap-2 hover:opacity-80 transition-opacity">
						<div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-sm shadow-lg text-white">🚀</div> 
						Alif<span class="text-blue-500">.Tech</span>
					</a>
					
					<div class="hidden lg:flex space-x-8 text-sm font-bold text-slate-300">
						<a href="/" class="text-white underline decoration-blue-500 decoration-4 underline-offset-8">Home</a>
						<a href="/template" class="hover:text-blue-500 transition-all">Template</a>
						<a href="/portofolio" class="hover:text-blue-500 transition-all">Portofolio</a>
						<a href="/harga" class="hover:text-blue-500 transition-all">Harga</a>
					</div>
					
					<div class="hidden lg:flex items-center gap-4 md:gap-5">
						<button id="theme-toggle-desktop" class="w-9 h-9 rounded-xl bg-slate-800 flex items-center justify-center text-slate-300 transition-all shadow-sm cursor-pointer hover:scale-105">
							🌙
						</button>
						<div class="flex items-center gap-3 text-sm font-bold">
							{isLoggedIn ? (
								<a href="/dashboard" class="text-blue-500 hover:text-blue-400 transition-colors">
									Dashboard Saya
								</a>
							) : (
								<>
									<a href="/login" class="text-slate-300 hover:text-blue-500 transition-colors">Login</a>
									<a href="/register" class="text-blue-500 hover:text-blue-400 transition-colors">Daftar</a>
								</>
							)}
						</div>
						<a href="https://wa.me/6281234567890" target="_blank" class="bg-blue-600 text-white px-6 py-2.5 rounded-full text-sm font-bold shadow-md hover:-translate-y-1 transition-transform">
							Konsultasi
						</a>
					</div>

					<button id="mobile-menu-btn" class="lg:hidden p-2 text-slate-300 hover:text-blue-500">
						<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
					</button>
				</div>
			</nav>

			<div id="mobile-menu" class="fixed inset-0 bg-slate-950/95 backdrop-blur-2xl z-40 transform translate-x-full transition-transform duration-300 flex flex-col items-center justify-center space-y-6 text-xl font-extrabold lg:hidden">
				<button id="theme-toggle-mobile" class="absolute top-24 w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center text-2xl text-slate-300 hover:scale-105 transition-transform">
					🌙
				</button>
				<a href="/" class="text-white hover:text-blue-500 transition-colors mt-10">Home</a>
				<a href="/template" class="text-slate-300 hover:text-blue-500 transition-colors">Template</a>
				<a href="/portofolio" class="text-slate-300 hover:text-blue-500 transition-colors">Portofolio</a>
				<a href="/harga" class="text-slate-300 hover:text-blue-500 transition-colors">Harga</a>
				<div class="w-16 h-px bg-slate-700 my-2"></div>
				<a href="/login" class="text-slate-300 hover:text-blue-500 transition-colors">Login</a>
				<a href="/register" class="text-blue-500 transition-colors">Daftar Klien Baru</a>
				<a href="https://wa.me/6281234567890" class="mt-4 bg-blue-600 text-white px-8 py-3 rounded-full text-base">Konsultasi WA</a>
			</div>
		</header>

		<main class="container mx-auto px-6 pt-56 pb-24 relative">
			<div class="flex flex-col lg:flex-row items-center gap-12">
				<div class="w-full lg:w-1/2 text-center lg:text-left relative z-10">
					<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 text-blue-500 text-xs font-bold tracking-wide mb-6">
						🌟 AGENSI WEB E-COMMERCE #1
					</div>
					
					<h1 class="text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
						Otomatisasi <br/>
						<span id="typewriter" class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-cyan-400 border-r-4 border-blue-500 pr-1">Bisnis Digital</span> <br/>
						Anda Hari Ini.
					</h1>

					<p class="text-lg text-slate-400 mb-8 max-w-lg leading-relaxed mx-auto lg:mx-0 transition-colors duration-500">
						Bangun ekosistem website yang terintegrasi langsung dengan Payment Gateway dan AI Assistant.
					</p>
					
					<div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
						<a href="/harga" class="w-full sm:w-auto bg-blue-600 text-white px-8 py-4 rounded-full font-black text-lg transition-all text-center shadow-lg btn-magnet">
							Lihat Paket Harga
						</a>
						<a href="/template" class="w-full sm:w-auto bg-slate-800 text-slate-300 px-8 py-4 rounded-full font-bold text-lg transition-all text-center hover:scale-105">
							Jelajahi Template
						</a>
					</div>
				</div>
				
				<div class="w-full lg:w-1/2 relative group hidden md:block">
					<div id="hero-glow" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-blue-600/20 rounded-full z-[-1] blur-[80px] transition-all duration-700"></div>
					
					<div class="bg-slate-800 rounded-[2rem] overflow-hidden transform md:rotate-2 group-hover:rotate-0 transition-all duration-500 shadow-2xl relative z-10 mockup-container">
						
						<div class="bg-slate-900 px-6 py-4 flex items-center gap-4 transition-colors duration-500 mockup-header">
							<div class="flex gap-2">
								<div class="w-3.5 h-3.5 rounded-full bg-red-500 shadow-sm"></div>
								<div class="w-3.5 h-3.5 rounded-full bg-yellow-500 shadow-sm"></div>
								<div class="w-3.5 h-3.5 rounded-full bg-green-500 shadow-sm"></div>
							</div>
							<div class="flex-1 max-w-md mx-auto bg-slate-800 px-4 py-2 rounded-lg text-sm text-slate-400 text-center font-medium flex items-center justify-center gap-2 mockup-url transition-colors duration-500">
								<svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7z"></path></svg>
								www.tokoanda.com
							</div>
						</div>

						<div class="p-8 relative overflow-hidden transition-colors duration-500 mockup-body">
							
							<div class="w-full h-40 bg-slate-700/50 rounded-2xl mb-8 flex flex-col items-center justify-center text-slate-400 font-bold relative overflow-hidden group/banner border-2 border-dashed border-slate-600 mockup-banner transition-colors duration-500">
								<div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/5 to-transparent -translate-x-full group-hover/banner:animate-[shimmer_1.5s_infinite]"></div>
								<svg class="w-8 h-8 mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
								<span>Banner Etalase Toko</span>
							</div>

							<div class="grid grid-cols-3 gap-6">
								<div class="h-32 bg-slate-700/30 rounded-2xl flex flex-col items-center justify-center gap-3 transition-all cursor-pointer mockup-category">
									<div class="w-14 h-14 bg-slate-800 rounded-full flex items-center justify-center text-3xl shadow-inner mockup-icon-bg transition-colors duration-500">🍔</div>
									<span class="text-xs font-bold text-slate-400 uppercase tracking-wider mockup-text transition-colors duration-500">F&B</span>
								</div>
								<div class="h-32 bg-slate-700/30 rounded-2xl flex flex-col items-center justify-center gap-3 transition-all cursor-pointer mockup-category">
									<div class="w-14 h-14 bg-slate-800 rounded-full flex items-center justify-center text-3xl shadow-inner mockup-icon-bg transition-colors duration-500">👕</div>
									<span class="text-xs font-bold text-slate-400 uppercase tracking-wider mockup-text transition-colors duration-500">Fashion</span>
