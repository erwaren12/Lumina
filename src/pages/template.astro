        <script is:inline>
            // SISTEM TOGGLE TEMA
            const btnDesktop = document.getElementById('theme-toggle-desktop');
            const btnMobile = document.getElementById('theme-toggle-mobile');
            const html = document.documentElement;
            
            // Default diset True (Light Mode)
            let isLight = true;
            function toggleTheme() {
                isLight = !isLight;
                if(isLight) {
                    html.setAttribute('data-theme', 'light');
                    if(btnDesktop) btnDesktop.innerText = '🌙';
                    if(btnMobile) btnMobile.innerText = '🌙';
                } else {
                    html.removeAttribute('data-theme');
                    if(btnDesktop) btnDesktop.innerText = '☀️';
                    if(btnMobile) btnMobile.innerText = '☀️';
                }
            }
            if(btnDesktop) btnDesktop.addEventListener('click', toggleTheme);
            if(btnMobile) btnMobile.addEventListener('click', toggleTheme);
            
            window.addEventListener('DOMContentLoaded', () => {
                // Memastikan button iconnya sinkron pas pertama kali load
                html.setAttribute('data-theme', 'light');
                if(btnDesktop) btnDesktop.innerText = '🌙';
                if(btnMobile) btnMobile.innerText = '🌙';
            });
            // MOBILE MENU TOGGLE
            const btnMenu = document.getElementById('mobile-menu-btn');
            const menu = document.getElementById('mobile-menu');
            let menuOpen = false;
            if(btnMenu) {
                btnMenu.addEventListener('click', () => {
                    menuOpen = !menuOpen;
                    if(menuOpen) {
                        menu.classList.remove('translate-x-full');
                        btnMenu.innerHTML = '<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
                    } else {
                        menu.classList.add('translate-x-full');
                        btnMenu.innerHTML = '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>';
                    }
                });
            }
        </script>
    </body>
</html>