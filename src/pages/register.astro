---
import '../styles/global.css';
---
<html lang="id" data-theme="light">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Buat Akun | Alif.Tech</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
        <style is:global>
            :root {
                --bg-card: #F5EEDB;      
                --text-dark: #2E1F1A;    
                --border-color: #C8B8A3; 
                --accent-color: #EA580C; 
            }

            body {
                background-color: var(--bg-card);
                color: var(--text-dark);
                font-family: 'Inter', sans-serif;
                margin: 0;
                padding: 0;
            }

            input:focus {
                outline: none;
                border-color: var(--accent-color) !important;
                box-shadow: 0 0 0 3px rgba(234, 88, 12, 0.1);
            }

            ::-webkit-scrollbar { width: 6px; } 
            ::-webkit-scrollbar-track { background: var(--bg-card); }
            ::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 10px; }
            
            input:-webkit-autofill {
                -webkit-box-shadow: 0 0 0 30px #FFFFFF inset !important;
                -webkit-text-fill-color: var(--text-dark) !important;
            }

            .teks-glow-putih {
                text-shadow: 0 2px 15px rgba(255, 255, 255, 0.9), 0 0 5px rgba(255, 255, 255, 0.5);
            }
        </style>
    </head>
    <body class="min-h-screen w-full antialiased selection:bg-[#EA580C] selection:text-white bg-[#F5EEDB]">
        
        <div class="flex flex-col lg:flex-row w-full min-h-screen">
            
            <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden flex-col justify-center p-8 lg:p-12 bg-white min-h-screen">
                <div class="absolute inset-0 z-0">
                    <img 
                        src="/gambar-daftar.jpg" 
                        alt="Background Register" 
                        class="w-full h-full object-cover object-[center_20%]"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#F5EEDB]/40 via-transparent to-transparent"></div>
                </div>
                
                <div class="relative z-10 text-center lg:text-left max-w-lg mx-auto lg:mx-0">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#2E1F1A] text-[#E3D5C1] text-[10px] font-black tracking-wide mb-4 shadow-md">
                        🚀 MULAI TRANSFORMASI
                    </div>
                    
                    <h1 class="text-3xl lg:text-4xl font-black mb-3 leading-tight text-[#2E1F1A] teks-glow-putih">
                        Langkah pertama mendominasi <span class="text-[#EA580C]">Pasar Online.</span>
                    </h1>
                    
                    <p class="text-[#2E1F1A] font-bold text-xs lg:text-sm leading-relaxed mb-6 teks-glow-putih">
                        Bergabunglah dengan ratusan pemilik bisnis lainnya yang telah mempercayakan infrastruktur digital mereka kepada Alif.Tech.
                    </p>

                    <ul class="space-y-3">
                        <li class="flex items-center gap-3 text-[#2E1F1A] font-bold text-xs lg:text-sm teks-glow-putih">
                            <div class="w-5 h-5 rounded-full bg-[#EA580C] text-white flex items-center justify-center shrink-0 shadow-md">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            Prioritas layanan antrean desain.
                        </li>
                        <li class="flex items-center gap-3 text-[#2E1F1A] font-bold text-xs lg:text-sm teks-glow-putih">
                            <div class="w-5 h-5 rounded-full bg-[#EA580C] text-white flex items-center justify-center shrink-0 shadow-md">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            Akses gratis ke AI Sales Agent.
                        </li>
                        <li class="flex items-center gap-3 text-[#2E1F1A] font-bold text-xs lg:text-sm teks-glow-putih">
                            <div class="w-5 h-5 rounded-full bg-[#EA580C] text-white flex items-center justify-center shrink-0 shadow-md">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            Keamanan server Enkripsi Tingkat Lanjut.
                        </li>
                    </ul>
                </div>
            </div>

            <div class="w-full lg:w-1/2 relative flex flex-col justify-center px-6 py-8 sm:px-12 lg:px-20 min-h-screen">
                
                <a href="/" class="absolute top-6 left-6 lg:top-8 lg:left-8 text-[#7B6153] hover:text-[#EA580C] font-bold text-xs flex items-center gap-1.5 transition-colors z-50">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Kembali ke Home
                </a>

                <div class="max-w-md mx-auto w-full">
                    <h2 class="text-2xl lg:text-3xl font-black text-left mb-1 text-[#2E1F1A]">Buat Akun Klien</h2>
                    <p class="text-xs font-bold text-[#7B6153] mb-5">Isi data diri Anda untuk membuat akun *dashboard* eksklusif.</p>

                    <form id="formRegister" class="space-y-2.5">
                        
                        <div>
                            <label class="block text-xs font-bold text-[#2E1F1A] mb-1">Nama Lengkap</label>
                            <input type="text" id="nama" placeholder="John Doe" class="w-full px-4 py-2.5 rounded-lg border border-[#C8B8A3] bg-white text-[#2E1F1A] placeholder-[#8A8173] transition-all" required />
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-[#2E1F1A] mb-1">Alamat Email</label>
                            <input type="email" id="email" placeholder="nama@email.com" class="w-full px-4 py-2.5 rounded-lg border border-[#C8B8A3] bg-white text-[#2E1F1A] placeholder-[#8A8173] transition-all" required />
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-[#2E1F1A] mb-1">Kata Sandi Baru</label>
                            <div class="relative">
                                <input type="password" id="password" placeholder="Minimal 8 karakter" class="w-full px-4 py-2.5 rounded-lg border border-[#C8B8A3] bg-white text-[#2E1F1A] placeholder-[#8A8173] transition-all" required minlength="8" />
                                <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#7B6153] hover:text-[#EA580C] transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path></svg>
                                </button>
                            </div>
                        </div>

                        <button type="submit" id="btnRegister" class="w-full py-2.5 bg-[#2E1F1A] text-[#E3D5C1] rounded-lg font-black text-sm hover:bg-[#4A332A] transition-all shadow-lg active:scale-95 flex items-center justify-center gap-2 mt-3">
                            <span>Daftar Sekarang</span>
                            <svg class="w-4 h-4 text-[#E3D5C1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-xs font-medium text-[#2E1F1A]">
                            Sudah punya akun? <a href="/login" class="text-[#EA580C] font-bold hover:underline transition-all">Masuk di sini</a>
                        </p>
                    </div>

                </div>
            </div>
        </div>

        <script is:inline>
            document.getElementById('formRegister').addEventListener('submit', async function(e) {
                e.preventDefault(); // Mencegah halaman refresh otomatis

                const nama = document.getElementById('nama').value;
                const email = document.getElementById('email').value;
                const password = document.getElementById('password').value;
                const btn = document.getElementById('btnRegister');

                // Ubah tampilan tombol saat loading
                btn.innerHTML = "Memproses... ⏳";
                btn.disabled = true;

                try {
                    // Mengirim request POST ke file /api/register.js
                    const response = await fetch('/api/register', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ nama, email, password })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        alert("🎉 " + result.message + " Silakan login dengan akun Anda.");
                        window.location.href = "/login"; // Otomatis pindah ke halaman login
                    } else {
                        // Jika gagal (misal: email sudah terdaftar)
                        alert("❌ Pendaftaran Gagal: " + result.message);
                        btn.innerHTML = '<span>Daftar Sekarang</span><svg class="w-4 h-4 text-[#E3D5C1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>';
                        btn.disabled = false;
                    }
                } catch (error) {
                    console.error("Error:", error);
                    alert("❌ Terjadi kesalahan pada sistem. Pastikan XAMPP dan MySQL Anda sudah berjalan.");
                    btn.innerHTML = '<span>Daftar Sekarang</span><svg class="w-4 h-4 text-[#E3D5C1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>';
                    btn.disabled = false;
                }
            });
        </script>
    </body>
</html>