---
import '../styles/global.css';
---
<html lang="id">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Harga Paket | Alif.Tech</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
        <style is:global>
            @keyframes shimmer { 100% { transform: translateX(100%); } }
            details > summary { list-style: none; }
            details > summary::-webkit-details-marker { display: none; }
            .hide-scrollbar::-webkit-scrollbar { display: none; }
            .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
            .kursor-tarik { cursor: grab; }
            .kursor-tarik:active { cursor: grabbing; }
            @keyframes blink { 0%, 100% { border-color: transparent; } 50% { border-color: #EA580C; } }
            
            /* ========================================================
               ☕ LIGHT MODE: WARM TERRACOTTA & BEIGE LINES EDITION
               ======================================================== */
            
            /* 1. Latar Belakang Dasar */
            [data-theme="light"] body { background-color: #F5EEDB !important; color: #2E1F1A !important; }
            
            /* Hapus background pembungkus bawaan dark mode */
            [data-theme="light"] .bg-slate-900, [data-theme="light"] .bg-slate-950, 
            [data-theme="light"] .bg-slate-900\/50, [data-theme="light"] .bg-slate-800\/30 { 
                background-color: transparent !important; }
            
            /* 2. Navigasi & Header */
            [data-theme="light"] header .bg-slate-950 { background-color: #F5EEDB !important; border: none !important; }
            [data-theme="light"] nav.bg-slate-900\/85 { background-color: rgba(245, 238, 219, 0.85) !important; border: none !important; backdrop-filter: blur(12px) !important; }
            [data-theme="light"] #mobile-menu { background-color: rgba(245, 238, 219, 0.98) !important; }

            /* 3. KOTAK/BOX: KREM KECOKELATAN */
            [data-theme="light"] .bg-slate-800,
            [data-theme="light"] .bg-slate-800\/40,
            [data-theme="light"] .bg-slate-800\/50,
            [data-theme="light"] .bg-slate-800\/80,
            [data-theme="light"] .pricing-card,
            [data-theme="light"] #terminal-card,
            [data-theme="light"] section.py-20 div.bg-gradient-to-r {
                background: #E3D5C1 !important; border: 1px solid #C8B8A3 !important; 
                border-radius: 1.5rem !important;
                box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.05) !important; }

            /* Efek Hover Pricing Card di Light Mode */
            [data-theme="light"] .pricing-card.popular {
                border-color: #EA580C !important; border-width: 2px !important;
                box-shadow: 0 10px 25px rgba(234, 88, 12, 0.15) !important; }

            /* 4. GARIS PEMISAH JADI COKELAT TIPIS */
            [data-theme="light"] .border-slate-800, 
            [data-theme="light"] .border-slate-700, 
            [data-theme="light"] .border-2, 
            [data-theme="light"] .border-t-2, 
            [data-theme="light"] .border-b-2 { 
                border-color: #C8B8A3 !important; border-width: 1px !important; }
            [data-theme="light"] .divide-slate-700 > :not([hidden]) ~ :not([hidden]) { 
                border-color: #C8B8A3 !important; border-width: 1px !important;
            }
            
            /* PEMUSNAH GARIS SEKAT DI KOTAK STATISTIK */
            [data-theme="light"] div#stats-grid > * { 
                border-left-width: 0px !important; border-right-width: 0px !important;
                border-top-width: 0px !important;
                border-bottom-width: 0px !important;
                border-color: transparent !important; }

            /* 5. TEKS GLOBAL JADI COKELAT TUA */
            [data-theme="light"] .text-white { color: #2E1F1A !important; }
            [data-theme="light"] .text-slate-300 { color: #2E1F1A !important; font-weight: 600 !important; }
            [data-theme="light"] .text-slate-400 { color: #7B6153 !important; font-weight: 500 !important; }
            [data-theme="light"] .text-slate-500 { color: #8A8173 !important; font-weight: 500 !important; }

            /* 6. Aksen Warna: Oranye Terracotta Halus */
            [data-theme="light"] .bg-blue-500\/10, [data-theme="light"] .bg-yellow-500\/10, [data-theme="light"] .bg-indigo-500\/10 { background-color: transparent !important; color: #EA580C !important; border: 1px solid #EA580C !important; border-radius: 0.5rem !important; }
            [data-theme="light"] .text-blue-500, [data-theme="light"] .text-blue-400 { color: #EA580C !important; font-weight: 800; } 
            [data-theme="light"] #typewriter { color: #EA580C !important; -webkit-text-fill-color: #EA580C !important; background: none !important; padding: 0; }
            [data-theme="light"] .border-cyan-400 { border-color: #EA580C !important; }
            [data-theme="light"] .decoration-blue-500 { text-decoration-color: #2E1F1A !important; text-decoration-thickness: 2px !important; }
            [data-theme="light"] .text-emerald-500 { color: #2E1F1A !important; }

            /* 7. Tombol CTA Utama */
            [data-theme="light"] .bg-blue-600, [data-theme="light"] .btn-primary { background-color: #2E1F1A !important; color: #E3D5C1 !important; border: none !important; border-radius: 9999px !important; }
            [data-theme="light"] .bg-blue-600:hover, [data-theme="light"] .btn-primary:hover { background-color: #524840 !important; }
            [data-theme="light"] .bg-blue-600 .text-white, [data-theme="light"] .btn-primary .text-white { color: #E3D5C1 !important; }
            [data-theme="light"] nav a.bg-blue-600 { background-color: #2E1F1A !important; color: #E3D5C1 !important; } 
            [data-theme="light"] .bg-white.text-blue-600 { background-color: #E3D5C1 !important; color: #2E1F1A !important; border: 1px solid #C8B8A3 !important; }

            /* Tombol outline di Harga */
            [data-theme="light"] .btn-outline { background-color: transparent !important; color: #2E1F1A !important; border: 2px solid #C8B8A3 !important; border-radius: 9999px !important;}
            [data-theme="light"] .btn-outline:hover { border-color: #EA580C !important; color: #EA580C !important; }

            /* 8. Elemen UI (Theme Toggle, WhatsApp melayang) */
            [data-theme="light"] #theme-toggle-desktop, [data-theme="light"] #theme-toggle-mobile { 
                background-color: transparent !important; border: 1px solid #C8B8A3 !important; color: #2E1F1A !important; 
            }
            [data-theme="light"] #theme-toggle-desktop:hover, [data-theme="light"] #theme-toggle-mobile:hover { background-color: #E5E7EB !important; color: #EA580C !important; }
            [data-theme="light"] a.fixed.bottom-6.right-6 svg.w-8.h-8 { color: #FFFFFF !important; }

            /* 9. Big CTA Banner Bawah */
            [data-theme="light"] section.py-20 div.bg-gradient-to-r {
                background: #E3D5C1 !important; border: 1px solid #C8B8A3 !important;
                border-radius: 2rem !important;
                box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.05) !important; }
            [data-theme="light"] section.py-20 div.bg-gradient-to-r .text-white { color: #2E1F1A !important; }
            [data-theme="light"] section.py-20 div.bg-white.text-blue-600 { background-color: #2E1F1A !important; color: #E3D5C1 !important; border: none !important; }

            /* 10. Mockup Etalase Toko */
            [data-theme="light"] div.bg-slate-900.px-4.py-3 { background-color: #E3D5C1 !important; border-bottom: 1px solid #C8B8A3 !important; }
            [data-theme="light"] div.bg-slate-800.px-3.py-1.rounded { background-color: transparent !important; color: #2E1F1A !important; border: 1px solid #C8B8A3 !important; }
            [data-theme="light"] .bg-slate-700\/50 { background-color: #F5EEDB !important; border: 1px solid #C8B8A3 !important; color: #7B6153 !important; }
            [data-theme="light"] .bg-slate-700\/30 { background-color: #E3D5C1 !important; border: 1px solid #C8B8A3 !important; }

            /* 11. CUSTOM STATS CONTAINER */
            [data-theme="light"] #stats-container {
                background-color: #E3D5C1 !important; border: 1px solid #C8B8A3 !important; 
                border-radius: 1.5rem !important; 
                box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.05) !important; }

            /* 12. PITA KLIEN UMKM */
            [data-theme="light"] #klien-banner {
                background-color: #2E1F1A !important; border-top: 1px solid #C8B8A3 !important;
                border-bottom: 1px solid #C8B8A3 !important; }
            [data-theme="light"] #klien-title { color: #EA580C !important; }
            [data-theme="light"] #klien-logos { filter: none !important; opacity: 1 !important; }
            [data-theme="light"] #klien-logos div { color: #E3D5C1 !important; }
            [data-theme="light"] #klien-logos span { color: #EA580C !important; }

            /* Miscellaneous */
            [data-theme="light"] .bg-blue-600\/20 { display: none !important; } 
            [data-theme="light"] .text-yellow-400 { color: #F59E0B !important; } 
            [data-theme="light"] #slider-testimoni .text-white { color: #2E1F1A !important; }
            [data-theme="light"] section.py-12 span.text-blue-500,
            [data-theme="light"] section.py-12 span.text-emerald-500,
            [data-theme="light"] section.py-12 span.text-purple-500 { color: #2E1F1A !important; }
            [data-theme="light"] section.py-12 span.counter { color: #2E1F1A !important; }
            
            /* Lencana Rekomendasi Light Mode */
            [data-theme="light"] .badge-popular { background-color: #EA580C !important; color: #F5EEDB !important;}
        </style>
        <script is:inline>
            document.documentElement.setAttribute('data-theme', 'light');
        </script>
    </head>
    <body class="bg-slate-900 text-slate-300 font-sans antialiased selection:bg-blue-500 selection:text-white flex flex-col min-h-screen transition-colors duration-500" style="font-family: 'Inter', sans-serif;">
        
