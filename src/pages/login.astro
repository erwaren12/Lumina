---
import '../styles/global.css';
---
<html lang="id" data-theme="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Masuk | Alif.Tech</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
		<style is:global>
			/* Palet Light Mode Alif.Tech */
			:root {
				--bg-card: #F5EEDB;      
				--text-dark: #2E1F1A;    
				--border-color: #C8B8A3; 
				--accent-color: #EA580C; 
			}

			body {
				background-color: var(--bg-card);
				color: var(--text-dark);
				font-family: 'Inter', sans-serif;
				margin: 0;
				padding: 0;
			}

			input:focus {
				outline: none;
				border-color: var(--accent-color) !important;
				box-shadow: 0 0 0 3px rgba(234, 88, 12, 0.1);
			}

			::-webkit-scrollbar { width: 8px; }
			::-webkit-scrollbar-track { background: var(--bg-card); }
			::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 10px; }
			::-webkit-scrollbar-thumb:hover { background: var(--accent-color); }
			
			input:-webkit-autofill {
				-webkit-box-shadow: 0 0 0 30px #FFFFFF inset !important;
				-webkit-text-fill-color: var(--text-dark) !important;
			}

			.teks-glow-putih {
				text-shadow: 0 2px 15px rgba(255, 255, 255, 0.9), 0 0 5px rgba(255, 255, 255, 0.5);
			}
		</style>
	</head>
	<body class="h-screen w-full antialiased selection:bg-[#EA580C] selection:text-white overflow-hidden">
		
		<div class="flex w-full h-screen bg-[#F5EEDB]">
			
			<div class="hidden lg:flex lg:w-1/2 relative overflow-hidden flex-col justify-center items-center text-center p-10 lg:p-16 bg-white">
				<div class="absolute inset-0 z-0">
					<img 
						src="/gambar-login.jpg" 
						alt="Background Login" 
						class="w-full h-full object-cover object-center"
					/>
				</div>
				
				<div class="relative z-10 mt-auto mb-10">
					<h1 class="text-4xl lg:text-5xl font-extrabold mb-3 leading-tight text-[#2E1F1A] teks-glow-putih">Wujudkan ide Anda</h1>
					<p class="text-[#2E1F1A] font-bold text-sm lg:text-base leading-relaxed max-w-md mx-auto teks-glow-putih">
						Masuk ke dashboard untuk memantau performa website dan mengatur integrasi Payment Gateway & AI Agent Anda.
					</p>
				</div>
			</div>

			<div class="w-full lg:w-1/2 relative flex flex-col bg-[#F5EEDB] h-screen overflow-y-auto px-6 sm:px-12 lg:px-20">
				
				<a href="/" class="absolute top-6 left-6 lg:top-8 lg:left-8 text-[#7B6153] hover:text-[#EA580C] font-bold text-sm flex items-center gap-2 transition-colors z-50">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
					Kembali ke Home
				</a>

				<div class="max-w-md mx-auto w-full py-16 my-auto">
					<h2 class="text-3xl font-black text-center mb-8 text-[#2E1F1A]">Masuk</h2>

                    <form id="formLogin" class="space-y-4">
						<div>
							<label class="block text-sm font-semibold text-[#2E1F1A] mb-1">Email Klien</label>
                            <input type="email" id="email" placeholder="nama@email.com" class="w-full px-4 py-3 rounded-xl border border-[#C8B8A3] bg-white text-[#2E1F1A] placeholder-[#8A8173] transition-all" required />
						</div>

						<div>
							<label class="block text-sm font-semibold text-[#2E1F1A] mb-1">Kata sandi</label>
							<div class="relative">
                                <input type="password" id="password" placeholder="Kata sandi" class="w-full px-4 py-3 rounded-xl border border-[#C8B8A3] bg-white text-[#2E1F1A] placeholder-[#8A8173] transition-all" required />
								<button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-[#7B6153] hover:text-[#EA580C] transition-colors">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path></svg>
								</button>
							</div>
							<a href="/lupa-sandi" class="inline-block mt-2 text-xs text-[#2E1F1A] underline font-medium hover:text-[#EA580C] transition-colors">Lupa kata sandi?</a>
						</div>

                        <button type="submit" id="btnLogin" class="w-full py-3 bg-[#2E1F1A] text-[#E3D5C1] rounded-xl font-bold text-base hover:bg-[#4A332A] transition-colors shadow-md mt-2 flex justify-center items-center">
							Masuk
						</button>
					</form>

					<div class="flex items-center my-5">
						<div class="flex-1 border-t border-[#C8B8A3]"></div>
						<span class="px-4 text-xs font-bold text-[#7B6153]">atau</span>
						<div class="flex-1 border-t border-[#C8B8A3]"></div>
					</div>

					<div class="text-center">
						<a href="/register" class="flex justify-center items-center w-full py-3 border border-[#C8B8A3] bg-transparent text-[#2E1F1A] rounded-xl font-bold hover:bg-[#E3D5C1] hover:border-[#2E1F1A] transition-all text-sm">
							Buat akun baru
						</a>
					</div>

				</div>
			</div>
		</div>

        <script is:inline>
            document.getElementById('formLogin').addEventListener('submit', async function(e) {
                e.preventDefault(); 

                const email = document.getElementById('email').value;
                const password = document.getElementById('password').value;
                const btn = document.getElementById('btnLogin');

                btn.innerHTML = "Memeriksa data... ⏳";
                btn.disabled = true;

                try {
                    const response = await fetch('/api/login', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ email, password })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        alert("✅ " + result.message + " Selamat datang kembali, " + result.nama + "!");
                        // Arahkan ke halaman utama (Home) setelah berhasil login
                        window.location.href = "/"; 
                    } else {
                        alert("❌ Gagal Masuk: " + result.message);
                        btn.innerHTML = "Masuk";
                        btn.disabled = false;
                    }
                } catch (error) {
                    console.error("Error:", error);
                    alert("❌ Terjadi kesalahan sistem. Coba lagi nanti.");
                    btn.innerHTML = "Masuk";
                    btn.disabled = false;
                }
            });
        </script>
	</body>
</html>